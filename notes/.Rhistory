library(urca)
data(Canada)   # from 'urca' package: interest rate, inflation, unemployment
# Recreate equivalent 'Canada' dataset manually
Canada <- data.frame(
e = c(6.4, 6.3, 6.3, 6.3, 6.4, 6.4, 6.5, 6.6, 6.7, 6.7, 6.8, 6.9, 7.0, 7.0, 7.1, 7.2,
7.3, 7.3, 7.4, 7.5, 7.6, 7.6, 7.7, 7.8, 7.9, 7.9, 8.0, 8.1, 8.2, 8.2, 8.3, 8.4,
8.5, 8.5, 8.6, 8.7, 8.8, 8.8, 8.9, 9.0, 9.1),  # Employment proxy
prod = cumsum(rnorm(40, 0.2, 0.1)),  # Simulated productivity growth
rw = cumsum(rnorm(40, 0.1, 0.15)),   # Real wages
U = c(7.2, 7.1, 7.2, 7.3, 7.4, 7.3, 7.4, 7.5, 7.6, 7.6, 7.7, 7.8, 7.9, 8.0, 8.0, 8.1,
8.2, 8.1, 8.0, 7.9, 7.8, 7.7, 7.6, 7.5, 7.5, 7.4, 7.3, 7.3, 7.2, 7.1, 7.0, 7.0,
6.9, 6.8, 6.7, 6.7, 6.6, 6.6, 6.5, 6.4)
)
# Fix: make all columns length 40
set.seed(123)
Canada <- data.frame(
e = c(6.4, 6.3, 6.3, 6.3, 6.4, 6.4, 6.5, 6.6, 6.7, 6.7,
6.8, 6.9, 7.0, 7.0, 7.1, 7.2, 7.3, 7.3, 7.4, 7.5,
7.6, 7.6, 7.7, 7.8, 7.9, 7.9, 8.0, 8.1, 8.2, 8.2,
8.3, 8.4, 8.5, 8.5, 8.6, 8.7, 8.8, 8.8, 8.9, 9.0),
prod = cumsum(rnorm(40, 0.2, 0.1)),   # simulated productivity
rw   = cumsum(rnorm(40, 0.1, 0.15)),  # simulated real wages
U    = seq(7.2, 6.4, length.out = 40) # unemployment rate
)
# Convert to time series object
Canada <- ts(Canada, start = c(1980, 1), frequency = 4)
# View and plot
head(Canada)
ts.plot(Canada, col = 1:4, lty = 1:4, main = "Synthetic 'Canada' Dataset", ylab = "Values")
legend("topleft", legend = colnames(Canada), col = 1:4, lty = 1:4)
